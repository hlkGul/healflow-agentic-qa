{
  "name": "healflow-agentic-qa",
  "version": "1.0.0",
  "description": "Self-healing agentic QA automation with Playwright + LangGraph + multi-provider LLM",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "node --import tsx node_modules/.bin/cucumber-js --import 'src/step-definitions/**/*.ts' --import 'src/support/**/*.ts' features/",
    "test:ci": "tsx src/ci-runner.ts",
    "generate": "tsx src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hlkGul/healflow-agentic-qa.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/hlkGul/healflow-agentic-qa/issues"
  },
  "homepage": "https://github.com/hlkGul/healflow-agentic-qa#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "openai": "^6.39.0"
  }
}
