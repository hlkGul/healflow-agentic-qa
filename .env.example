# LLM Provider Configuration (set at least one API key)
# Auto-detection: GEMINI_API_KEY found → uses Gemini; OPENAI_API_KEY found → uses OpenAI
# Override with LLM_PROVIDER=gemini or LLM_PROVIDER=openai

GEMINI_API_KEY=your_gemini_api_key_here
